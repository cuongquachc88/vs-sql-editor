{
  "name": "vs-sql-editor",
  "displayName": "VS SQL Editor",
  "description": "SQL client for VS Code — connect to PostgreSQL, MySQL, SQLite, PGlite & ClickHouse. Run queries, browse schema, edit rows, import CSV, visualize ERDs, and generate SQL with AI.",
  "version": "0.1.4",
  "publisher": "cuongquachc88",
  "author": {
    "name": "cuongquachc88",
    "email": "cuongquachc88@gmail.com"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "license": "MIT",
  "qna": false,
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "keywords": [
    "sql",
    "database",
    "postgres",
    "postgresql",
    "mysql",
    "sqlite",
    "clickhouse",
    "pglite",
    "query",
    "db client",
    "schema explorer",
    "erd",
    "csv import",
    "ai sql"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cuongquachc88/vs-sql-editor.git"
  },
  "homepage": "https://github.com/cuongquachc88/vs-sql-editor#readme",
  "bugs": {
    "url": "https://github.com/cuongquachc88/vs-sql-editor/issues",
    "email": "cuongquachc88@gmail.com"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:sql",
    "onView:vsSqlEditorConnections",
    "onNotebook:vsSqlEditor.notebook"
  ],
  "categories": [
    "Programming Languages",
    "Data Science",
    "Other"
  ],
  "contributes": {
    "commands": [
      {
        "command": "vsSqlEditor.addConnection",
        "title": "SQL: Add Connection",
        "icon": "$(add)"
      },
      {
        "command": "vsSqlEditor.runQuery",
        "title": "SQL: Run Query",
        "icon": "$(debug-start)"
      },
      {
        "command": "vsSqlEditor.runAll",
        "title": "SQL: Run All",
        "icon": "$(run-all)"
      },
      {
        "command": "vsSqlEditor.runSelected",
        "title": "SQL: Run Selection",
        "icon": "$(run-below)"
      },
      {
        "command": "vsSqlEditor.selectConnection",
        "title": "SQL: Select Active Connection"
      },
      {
        "command": "vsSqlEditor.refreshExplorer",
        "title": "SQL: Refresh Schema Explorer",
        "icon": "$(refresh)"
      },
      {
        "command": "vsSqlEditor.previewTable",
        "title": "SQL: Preview Table Data"
      },
      {
        "command": "vsSqlEditor.setActiveConnection",
        "title": "SQL: Set Active Connection",
        "icon": "$(check)"
      },
      {
        "command": "vsSqlEditor.editConnection",
        "title": "SQL: Edit Connection",
        "icon": "$(edit)"
      },
      {
        "command": "vsSqlEditor.duplicateConnection",
        "title": "SQL: Duplicate Connection",
        "icon": "$(copy)"
      },
      {
        "command": "vsSqlEditor.deleteConnection",
        "title": "SQL: Delete Connection",
        "icon": "$(trash)"
      },
      {
        "command": "vsSqlEditor.welcome",
        "title": "SQL: Open Welcome",
        "icon": "$(home)"
      },
      {
        "command": "vsSqlEditor.newQuery",
        "title": "SQL: New Query",
        "icon": "$(new-file)"
      },
      {
        "command": "vsSqlEditor.openErd",
        "title": "SQL: Open ERD Diagram",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "vsSqlEditor.importCsv",
        "title": "SQL: Import CSV",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "vsSqlEditor.aiAskSql",
        "title": "SQL: AI — Ask in plain English",
        "icon": "$(sparkle)"
      },
      {
        "command": "vsSqlEditor.aiExplain",
        "title": "SQL: AI — Explain Query",
        "icon": "$(book)"
      },
      {
        "command": "vsSqlEditor.aiSuggestFix",
        "title": "SQL: AI — Suggest Fix for Last Error"
      },
      {
        "command": "vsSqlEditor.aiSetOpenAiKey",
        "title": "SQL: AI — Set OpenAI API Key"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vsSqlEditor",
          "title": "SQL Editor",
          "icon": "$(database)"
        }
      ]
    },
    "views": {
      "vsSqlEditor": [
        {
          "id": "vsSqlEditorConnections",
          "name": "Connections",
          "type": "webview",
          "icon": "$(database)"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "command": "vsSqlEditor.runAll",
          "when": "resourceLangId == sql",
          "group": "navigation@0"
        },
        {
          "command": "vsSqlEditor.runSelected",
          "when": "resourceLangId == sql",
          "group": "navigation@1"
        },
        {
          "command": "vsSqlEditor.aiAskSql",
          "when": "resourceLangId == sql",
          "group": "navigation@2"
        },
        {
          "command": "vsSqlEditor.aiExplain",
          "when": "resourceLangId == sql",
          "group": "navigation@3"
        },
        {
          "command": "vsSqlEditor.newQuery",
          "when": "resourceLangId == sql",
          "group": "navigation@4"
        }
      ],
      "editor/context": [
        {
          "command": "vsSqlEditor.runAll",
          "when": "resourceLangId == sql",
          "group": "1_sql@1"
        },
        {
          "command": "vsSqlEditor.runSelected",
          "when": "resourceLangId == sql && editorHasSelection",
          "group": "1_sql@2"
        }
      ],
      "view/title": [
        {
          "command": "vsSqlEditor.newQuery",
          "when": "view == vsSqlEditorConnections",
          "group": "navigation@0"
        },
        {
          "command": "vsSqlEditor.welcome",
          "when": "view == vsSqlEditorConnections",
          "group": "navigation@1"
        },
        {
          "command": "vsSqlEditor.openErd",
          "when": "view == vsSqlEditorConnections",
          "group": "navigation@2"
        },
        {
          "command": "vsSqlEditor.importCsv",
          "when": "view == vsSqlEditorConnections",
          "group": "navigation@3"
        },
        {
          "command": "vsSqlEditor.addConnection",
          "when": "view == vsSqlEditorConnections",
          "group": "navigation@4"
        },
        {
          "command": "vsSqlEditor.refreshExplorer",
          "when": "view == vsSqlEditorConnections",
          "group": "navigation@5"
        }
      ],
      "commandPalette": [
        { "command": "vsSqlEditor.editConnection", "when": "false" },
        { "command": "vsSqlEditor.duplicateConnection", "when": "false" },
        { "command": "vsSqlEditor.deleteConnection", "when": "false" },
        { "command": "vsSqlEditor.setActiveConnection", "when": "false" },
        { "command": "vsSqlEditor.previewTable", "when": "false" }
      ]
    },
    "notebooks": [
      {
        "type": "vsSqlEditor.notebook",
        "displayName": "SQL Notebook",
        "selector": [
          { "filenamePattern": "*.sqlnb" }
        ]
      }
    ],
    "notebookRenderer": [
      {
        "id": "vsSqlEditor.resultRenderer",
        "displayName": "SQL Result Grid",
        "entrypoint": "./dist/sqlnb-renderer.js",
        "mimeTypes": [
          "application/x-vssqleditor-result+json",
          "application/x-vssqleditor-error+json"
        ]
      }
    ],
    "keybindings": [
      {
        "command": "vsSqlEditor.runQuery",
        "key": "f5",
        "when": "editorTextFocus && resourceLangId == sql"
      },
      {
        "command": "vsSqlEditor.runQuery",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "editorTextFocus && resourceLangId == sql"
      }
    ],
    "configuration": {
      "title": "VS SQL Editor",
      "properties": {
        "vsSqlEditor.pageSize": {
          "type": "number",
          "default": 500,
          "description": "Rows per results page"
        },
        "vsSqlEditor.ai.provider": {
          "type": "string",
          "enum": ["auto", "vscode-lm", "openai"],
          "default": "auto",
          "description": "Which language-model backend to use. \"auto\" prefers VS Code's Language Model API (e.g. Copilot) and falls back to OpenAI when an API key is configured."
        },
        "vsSqlEditor.ai.openai.baseUrl": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "description": "Base URL for the OpenAI-compatible HTTP endpoint."
        },
        "vsSqlEditor.ai.openai.model": {
          "type": "string",
          "default": "gpt-4o-mini",
          "description": "Model name for the OpenAI-compatible endpoint."
        },
        "vsSqlEditor.ai.inline.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable schema-aware AI ghost completions in SQL files."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "test": "vitest run",
    "test:integration": "./scripts/test-integration.sh",
    "test:integration:keep": "./scripts/test-integration.sh --keep",
    "test:all": "npm test && npm run test:integration",
    "typecheck": "tsc --noEmit",
    "package": "mkdir -p out && vsce package --out out/",
    "install:vsix": "code --install-extension \"out/vs-sql-editor-$(node -p 'require(\"./package.json\").version').vsix\" --force",
    "deploy": "npm run package && npm run install:vsix",
    "publish": "vsce publish --packagePath \"out/vs-sql-editor-$(node -p 'require(\"./package.json\").version').vsix\"",
    "vscode:prepublish": "node esbuild.mjs --production"
  },
  "dependencies": {
    "@clickhouse/client": "^1.20.0",
    "@electric-sql/pglite": "^0.2.17",
    "csv-stringify": "^6.5.0",
    "mysql2": "^3.22.5",
    "pg": "^8.13.0",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.0",
    "@types/sql.js": "^1.4.11",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.23.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
