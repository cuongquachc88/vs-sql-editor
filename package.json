{
  "name": "vs-sql-editor",
  "displayName": "VS SQL Editor",
  "description": "Connect to and edit SQL across Postgres, MySQL, PGlite, SQLite, ClickHouse",
  "version": "0.0.1",
  "publisher": "cuongquachc88",
  "author": {
    "name": "cuongquachc88",
    "email": "cuongquachc88@gmail.com"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "license": "MIT",
  "qna": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/cuongquachc88/vs-sql-editor.git"
  },
  "homepage": "https://github.com/cuongquachc88/vs-sql-editor#readme",
  "bugs": {
    "url": "https://github.com/cuongquachc88/vs-sql-editor/issues",
    "email": "cuongquachc88@gmail.com"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:sql",
    "onView:vsSqlEditorExplorer"
  ],
  "categories": [
    "Other"
  ],
  "contributes": {
    "commands": [
      {
        "command": "vsSqlEditor.addConnection",
        "title": "SQL: Add Connection",
        "icon": "$(add)"
      },
      {
        "command": "vsSqlEditor.runQuery",
        "title": "SQL: Run Query"
      },
      {
        "command": "vsSqlEditor.selectConnection",
        "title": "SQL: Select Active Connection"
      },
      {
        "command": "vsSqlEditor.refreshExplorer",
        "title": "SQL: Refresh Schema Explorer",
        "icon": "$(refresh)"
      },
      {
        "command": "vsSqlEditor.previewTable",
        "title": "SQL: Preview Table Data"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vsSqlEditor",
          "title": "SQL Editor",
          "icon": "$(database)"
        }
      ]
    },
    "views": {
      "vsSqlEditor": [
        {
          "id": "vsSqlEditorExplorer",
          "name": "Connections",
          "icon": "$(database)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "vsSqlEditorExplorer",
        "contents": "No SQL connections yet.\n[Add Connection](command:vsSqlEditor.addConnection)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "vsSqlEditor.addConnection",
          "when": "view == vsSqlEditorExplorer",
          "group": "navigation@1"
        },
        {
          "command": "vsSqlEditor.refreshExplorer",
          "when": "view == vsSqlEditorExplorer",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "VS SQL Editor",
      "properties": {
        "vsSqlEditor.pageSize": {
          "type": "number",
          "default": 500,
          "description": "Rows per results page"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "package": "vsce package",
    "install:vsix": "code --install-extension vs-sql-editor-0.0.1.vsix --force",
    "deploy": "npm run package && npm run install:vsix",
    "vscode:prepublish": "node esbuild.mjs --production"
  },
  "dependencies": {
    "@clickhouse/client": "^1.20.0",
    "@electric-sql/pglite": "^0.2.17",
    "csv-stringify": "^6.5.0",
    "mysql2": "^3.22.5",
    "pg": "^8.13.0",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.0",
    "@types/sql.js": "^1.4.11",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.23.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
